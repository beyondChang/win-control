*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# OS-specific files
.DS_Store
Thumbs.db

# Version control files
.svn/

# Release folder
/app/release

# App build folder
/app/build

# AI assistant files
AGENTS.md

# Google Services (e.g. Maps or AdMob)
google-services.json

# Fabric
fabric.properties

# Heap dump files
*.hprof

# Android Profiling
*.hprof